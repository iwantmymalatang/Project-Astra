<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Project ASTRA is an accessible student radio astronomy platform for 1420 MHz hydrogen-line observation, telescope engineering, RF signal processing, and future interferometry." />
  <title>Project ASTRA | Student Radio Astronomy</title>
  <style>
    :root {
      --bg: #03040a;
      --bg2: #071025;
      --panel: rgba(255,255,255,.065);
      --panel2: rgba(255,255,255,.1);
      --line: rgba(255,255,255,.14);
      --text: #f6f8ff;
      --muted: #aab5d6;
      --soft: #d7e0ff;
      --accent: #8eb7ff;
      --accent2: #b98cff;
      --cyan: #7de8ff;
      --shadow: 0 30px 100px rgba(0,0,0,.42);
      --radius: 30px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      min-height: 100vh;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 10% 8%, rgba(104,147,255,.22), transparent 28%),
        radial-gradient(circle at 78% 18%, rgba(185,140,255,.18), transparent 30%),
        radial-gradient(circle at 50% 95%, rgba(125,232,255,.12), transparent 36%),
        linear-gradient(180deg, var(--bg), var(--bg2) 45%, #03040a);
      line-height: 1.65;
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image: radial-gradient(rgba(255,255,255,.9) .7px, transparent .7px);
      background-size: 48px 48px;
      opacity: .13;
      pointer-events: none;
      z-index: -2;
    }
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px),
        linear-gradient(180deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 100px 100px;
      mask-image: radial-gradient(circle at 50% 35%, black, transparent 72%);
      pointer-events: none;
      z-index: -1;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; width: 100%; height: auto; }
    .container { width: min(1180px, calc(100% - 40px)); margin: 0 auto; }

    .nav {
      position: sticky; top: 0; z-index: 50;
      background: rgba(3,4,10,.65);
      border-bottom: 1px solid rgba(255,255,255,.08);
      backdrop-filter: blur(18px);
    }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 20px 0; }
    .brand { display: inline-flex; align-items: center; gap: 12px; font-weight: 750; letter-spacing: .16em; text-transform: uppercase; font-size: .9rem; }
    .brand-mark { width: 30px; height: 30px; border-radius: 50%; border: 1px solid rgba(255,255,255,.35); position: relative; box-shadow: 0 0 32px rgba(142,183,255,.55); }
    .brand-mark::before { content: ""; position: absolute; inset: 7px; border-radius: 50%; border: 1px dashed rgba(255,255,255,.25); }
    .brand-mark::after { content: ""; position: absolute; width: 7px; height: 7px; border-radius: 50%; right: -2px; top: 7px; background: var(--cyan); box-shadow: 0 0 20px var(--cyan); }
    .nav-links { display: flex; gap: 24px; color: var(--muted); font-size: .92rem; }
    .nav-links a:hover { color: var(--text); }

    .hero { min-height: 92vh; display: grid; align-items: center; padding: 105px 0 130px; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 68px; align-items: center; }
    .eyebrow { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 28px; padding: 8px 14px; border-radius: 999px; border: 1px solid rgba(142,183,255,.28); background: rgba(142,183,255,.08); color: var(--accent); letter-spacing: .14em; text-transform: uppercase; font-size: .76rem; }
    .pulse { width: 7px; height: 7px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 20px var(--cyan); }
    h1 { max-width: 900px; font-size: clamp(3.5rem, 8vw, 8.7rem); line-height: .88; letter-spacing: -.085em; margin-bottom: 32px; }
    .hero-lead { color: var(--soft); max-width: 720px; font-size: clamp(1.12rem, 2vw, 1.38rem); margin-bottom: 42px; }
    .actions { display: flex; flex-wrap: wrap; gap: 14px; }
    .button { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 13px 21px; border-radius: 999px; border: 1px solid rgba(255,255,255,.18); background: rgba(255,255,255,.06); transition: .2s ease; }
    .button.primary { background: var(--text); color: #03040a; border-color: var(--text); }
    .button:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.34); }

    .hero-card { border-radius: 40px; overflow: hidden; border: 1px solid var(--line); background: var(--panel); box-shadow: var(--shadow); position: relative; min-height: 560px; }
    .hero-card img { height: 560px; object-fit: cover; filter: saturate(.92) contrast(1.05) brightness(.82); }
    .hero-card::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(3,4,10,.86)); }
    .stats { position: absolute; left: 20px; right: 20px; bottom: 20px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; z-index: 2; }
    .stat { padding: 14px; border-radius: 18px; border: 1px solid rgba(255,255,255,.14); background: rgba(3,4,10,.72); backdrop-filter: blur(12px); }
    .stat strong { display: block; font-size: 1.18rem; }
    .stat span { color: var(--muted); font-size: .77rem; }

    section { padding: 112px 0; }
    .section-head { max-width: 820px; margin-bottom: 52px; }
    .label { color: var(--accent); font-size: .78rem; letter-spacing: .16em; text-transform: uppercase; margin-bottom: 15px; }
    h2 { font-size: clamp(2.1rem, 5vw, 4.7rem); line-height: .96; letter-spacing: -.06em; margin-bottom: 20px; }
    .section-head p, .large-text { color: var(--muted); font-size: 1.08rem; max-width: 840px; }
    .mission-panel { padding: clamp(30px, 5vw, 58px); border-radius: 38px; border: 1px solid rgba(142,183,255,.28); background: linear-gradient(135deg, rgba(142,183,255,.13), rgba(185,140,255,.08)), rgba(255,255,255,.05); box-shadow: var(--shadow); }
    .mission-panel p { color: var(--text); font-size: clamp(1.35rem, 3vw, 2.35rem); line-height: 1.22; letter-spacing: -.045em; }

    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .card { min-height: 245px; padding: 28px; border-radius: var(--radius); border: 1px solid var(--line); background: var(--panel); backdrop-filter: blur(16px); }
    .card.media { padding: 0; overflow: hidden; }
    .card.media img { height: 265px; object-fit: cover; }
    .card.media .copy { padding: 24px; }
    .card-number { color: var(--accent); font-size: .78rem; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 42px; }
    h3 { font-size: 1.25rem; margin-bottom: 12px; letter-spacing: -.02em; }
    .card p, .card li, .timeline-item div:last-child { color: var(--muted); font-size: .98rem; }
    ul { list-style: none; display: grid; gap: 10px; margin-top: 16px; }
    li::before { content: "✦"; color: var(--accent); margin-right: 10px; }

    .feature-row { display: grid; grid-template-columns: .95fr 1.05fr; gap: 22px; align-items: stretch; }
    .feature-image { min-height: 420px; border-radius: 34px; overflow: hidden; border: 1px solid var(--line); background: var(--panel); box-shadow: var(--shadow); }
    .feature-image img { height: 100%; object-fit: cover; }
    .feature-copy { padding: 38px; border-radius: 34px; border: 1px solid var(--line); background: var(--panel); }

    .pipeline { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
    .pipe-step { min-height: 155px; padding: 22px; border: 1px solid var(--line); border-radius: 24px; background: rgba(255,255,255,.055); position: relative; }
    .pipe-step::after { content: "→"; position: absolute; right: -14px; top: 50%; transform: translateY(-50%); color: var(--accent); }
    .pipe-step:last-child::after { display: none; }
    .pipe-step span { color: var(--accent); font-size: .78rem; letter-spacing: .12em; text-transform: uppercase; }
    .pipe-step h3 { margin-top: 18px; }

    .spec-table { width: 100%; border-collapse: collapse; overflow: hidden; border-radius: 24px; border: 1px solid var(--line); background: rgba(255,255,255,.045); }
    .spec-table th, .spec-table td { padding: 18px; text-align: left; border-bottom: 1px solid rgba(255,255,255,.09); color: var(--muted); }
    .spec-table th { color: var(--text); font-weight: 700; background: rgba(255,255,255,.065); }
    .spec-table tr:last-child td { border-bottom: 0; }

    .gallery { display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px; }
    .gallery-card { border-radius: 28px; overflow: hidden; border: 1px solid var(--line); background: var(--panel); min-height: 260px; position: relative; }
    .gallery-card.large { grid-column: span 7; min-height: 430px; }
    .gallery-card.medium { grid-column: span 5; min-height: 430px; }
    .gallery-card.small { grid-column: span 4; }
    .gallery-card img { height: 100%; object-fit: cover; }
    .caption { position: absolute; left: 16px; right: 16px; bottom: 16px; z-index: 2; padding: 14px; border-radius: 18px; background: rgba(3,4,10,.72); border: 1px solid rgba(255,255,255,.12); backdrop-filter: blur(12px); }
    .caption strong { display: block; }
    .caption span { display: block; color: var(--muted); font-size: .85rem; }
    .gallery-card::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(3,4,10,.86)); pointer-events: none; }

    .timeline { display: grid; gap: 14px; }
    .timeline-item { display: grid; grid-template-columns: 125px 1fr; gap: 18px; padding: 20px; border: 1px solid var(--line); border-radius: 24px; background: rgba(255,255,255,.045); }
    .month { color: var(--accent); font-weight: 750; letter-spacing: .08em; text-transform: uppercase; font-size: .82rem; }

    .footer { padding: 70px 0 90px; border-top: 1px solid rgba(255,255,255,.08); color: var(--muted); }
    .footer-inner { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .reveal { opacity: 0; transform: translateY(18px); transition: .7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 960px) {
      .hero-grid, .feature-row, .grid-3, .grid-2, .pipeline { grid-template-columns: 1fr; }
      .nav-links { display: none; }
      .hero { padding: 85px 0 110px; }
      .hero-card, .hero-card img { min-height: 420px; height: 420px; }
      .pipe-step::after { display: none; }
      .gallery { grid-template-columns: 1fr; }
      .gallery-card.large, .gallery-card.medium, .gallery-card.small { grid-column: auto; min-height: 320px; }
      .timeline-item { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <a class="brand" href="#top" aria-label="Project ASTRA home"><span class="brand-mark"></span><span>Project ASTRA</span></a>
      <div class="nav-links">
        <a href="#mission">Mission</a>
        <a href="#design">Design</a>
        <a href="#prototype">Prototype</a>
        <a href="#network">Network</a>
        <a href="#roadmap">Roadmap</a>
      </div>
    </div>
  </nav>

  <main id="top">
    <section class="hero">
      <div class="container hero-grid">
        <div class="reveal">
          <div class="eyebrow"><span class="pulse"></span> 1420 MHz • Hydrogen Line • Student Built</div>
          <h1>Radio astronomy for every curious student.</h1>
          <p class="hero-lead">Project ASTRA is a low-cost, customizable radio telescope platform for schools, astronomy CCAs, and research students — built to make hydrogen-line astronomy, RF signal processing, telescope engineering, and interferometry accessible.</p>
          <div class="actions">
            <a class="button primary" href="#mission">Explore the Mission</a>
            <a class="button" href="#prototype">View Prototype</a>
          </div>
        </div>
        <div class="hero-card reveal">
          <img src="assets/hero_dish.jpg" alt="Project ASTRA 1-meter parabolic dish prototype" />
          <div class="stats">
            <div class="stat"><strong>1 m</strong><span>ASTRA 100A</span></div>
            <div class="stat"><strong>0.4</strong><span>f/D ratio</span></div>
            <div class="stat"><strong>21 cm</strong><span>HI line</span></div>
          </div>
        </div>
      </div>
    </section>

    <section id="mission">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">Mission</div>
          <h2>Make the invisible sky accessible.</h2>
        </div>
        <div class="mission-panel reveal">
          <p>ASTRA exists to turn radio astronomy from something locked inside expensive facilities into a hands-on learning platform that students can build, modify, observe with, and expand into collaborative telescope arrays.</p>
        </div>
      </div>
    </section>

    <section id="problem">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">Problem & Context</div>
          <h2>Students need access to real signals, not just theory.</h2>
          <p>Professional radio telescopes are expensive, difficult to access, and usually not designed for student-level customization. ASTRA bridges the gap by combining an affordable dish, feedhorn, receiver chain, and software pipeline that students can understand from first principles.</p>
        </div>
        <div class="grid-3">
          <article class="card reveal"><div class="card-number">01</div><h3>Astrophysics</h3><p>Observe the 1420 MHz neutral hydrogen line to explore the structure and dynamics of the Milky Way.</p></article>
          <article class="card reveal"><div class="card-number">02</div><h3>Engineering</h3><p>Build a parabolic reflector, feedhorn, Az-El mount, gearing system, and stable mechanical platform.</p></article>
          <article class="card reveal"><div class="card-number">03</div><h3>Computing</h3><p>Process spectra through SDR and software tools, then extend toward synchronization and correlation.</p></article>
        </div>
      </div>
    </section>

    <section id="design">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">System Design</div>
          <h2>A modular 1420 MHz telescope platform.</h2>
          <p>The ASTRA 100A uses a 1-meter parabolic reflector, pyramidal feedhorn, Az-El rotating base, low-noise amplifier, software-defined radio, and computer-side signal processing.</p>
        </div>
        <div class="feature-row reveal">
          <div class="feature-image"><img src="assets/dish_render.jpg" alt="CAD rendering of ASTRA parabolic dish" /></div>
          <div class="feature-copy">
            <div class="label">ASTRA 100A</div>
            <h2>Designed for real student construction.</h2>
            <p class="large-text">The reflector is split into printable segments, then sanded and covered with a conductive aluminium layer to reflect incoming radio waves toward the focus. The structure supports both quick assembly and more permanent screw or rivet-based construction.</p>
            <ul>
              <li>1-meter parabolic dish with f/D = 0.4</li>
              <li>3D-printed segmented reflector</li>
              <li>Aluminium reflective surface</li>
              <li>Portable design for school deployment</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="components">
      <div class="container">
        <div class="grid-3">
          <article class="card media reveal">
            <img src="assets/feedhorn_render.png" alt="Pyramidal feedhorn CAD design" />
            <div class="copy"><h3>Pyramidal feedhorn</h3><p>Selected for ease of fabrication, controllable beamwidth, and practical 1420 MHz dish illumination.</p></div>
          </article>
          <article class="card media reveal">
            <img src="assets/mount_render.jpg" alt="Azimuth elevation mount CAD design" />
            <div class="copy"><h3>Az-El mount</h3><p>Points the telescope across the sky using azimuth and elevation movement with stepper motor control.</p></div>
          </article>
          <article class="card media reveal">
            <img src="assets/electronics_lna.jpg" alt="Low noise amplifier component for radio telescope receiver chain" />
            <div class="copy"><h3>Receiver chain</h3><p>Signal path: feedhorn probe → low-noise amplifier → software-defined radio → processing software.</p></div>
          </article>
        </div>
      </div>
    </section>

    <section id="pipeline">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">Hardware Pipeline</div>
          <h2>From cosmic radio waves to student data.</h2>
        </div>
        <div class="pipeline">
          <div class="pipe-step reveal"><span>Step 01</span><h3>Telescope</h3><p class="large-text">The dish and feedhorn collect and couple weak 1420 MHz radio signals.</p></div>
          <div class="pipe-step reveal"><span>Step 02</span><h3>LNA</h3><p class="large-text">A low-noise amplifier placed near the feed preserves the faint signal.</p></div>
          <div class="pipe-step reveal"><span>Step 03</span><h3>SDR</h3><p class="large-text">A software-defined radio digitizes the received spectrum.</p></div>
          <div class="pipe-step reveal"><span>Step 04</span><h3>Software</h3><p class="large-text">GNU Radio or custom tools process, visualize, and store observations.</p></div>
        </div>
      </div>
    </section>

    <section id="models">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">Models</div>
          <h2>ASTRA 100A and ASTRA 230A.</h2>
          <p>ASTRA begins with a feasible 1-meter prototype and extends toward a larger 2.3-meter design for improved capability and comparison with commercial systems.</p>
        </div>
        <table class="spec-table reveal">
          <thead><tr><th>Specification</th><th>ASTRA 100A</th><th>ASTRA 230A</th></tr></thead>
          <tbody>
            <tr><td>Dish diameter</td><td>1 meter</td><td>2.3 meters</td></tr>
            <tr><td>Focal ratio</td><td>0.4</td><td>0.4</td></tr>
            <tr><td>Reflector type</td><td>Parabolic</td><td>Parabolic</td></tr>
            <tr><td>Feed</td><td>Pyramidal feedhorn</td><td>Pyramidal feedhorn</td></tr>
            <tr><td>Mount</td><td>Az-El rotating base</td><td>Larger Az-El rotating base</td></tr>
            <tr><td>Estimated weight</td><td>~4.056 kg</td><td>≤ 28 kg target</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section id="prototype">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">Prototype Gallery</div>
          <h2>From CAD to physical build.</h2>
          <p>ASTRA is built around practical fabrication: printed dish sections, mechanical ribs, secure clips, reflective lining, and a receiver chain that students can assemble and understand.</p>
        </div>
        <div class="gallery">
          <div class="gallery-card large reveal"><img src="assets/dish_detail_1.jpg" alt="Close view of ASTRA parabolic dish ribs and panels" /><div class="caption"><strong>Dish structure</strong><span>Segmented reflector with ribs and panel joints.</span></div></div>
          <div class="gallery-card medium reveal"><img src="assets/dish_side_render.jpg" alt="Side CAD view of ASTRA parabolic dish" /><div class="caption"><strong>Dish geometry</strong><span>CAD view of reflector shape and focal structure.</span></div></div>
          <div class="gallery-card small reveal"><img src="assets/dish_detail_2.jpg" alt="Prototype dish panel details" /><div class="caption"><strong>Assembly details</strong><span>Printed sections designed for repeatable construction.</span></div></div>
          <div class="gallery-card small reveal"><img src="assets/dish_detail_3.jpg" alt="ASTRA reflector panel seam details" /><div class="caption"><strong>Reflector panels</strong><span>Panel alignment and surface finishing process.</span></div></div>
          <div class="gallery-card small reveal"><img src="assets/dish_clip.jpg" alt="Secure clip and fastening detail on ASTRA dish prototype" /><div class="caption"><strong>Fastening</strong><span>Clips and screws improve rigidity and portability.</span></div></div>
        </div>
      </div>
    </section>

    <section id="network">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">Long-Term Vision</div>
          <h2>An island-wide student interferometry network.</h2>
          <p>The ideal future is a modular network of school-based ASTRA telescopes. Each school can use its telescope independently, while the wider network can explore synchronization, correlation, and interferometric concepts.</p>
        </div>
        <div class="feature-row reveal">
          <div class="feature-copy">
            <div class="label">Accessible Collaboration</div>
            <h2>One telescope becomes many.</h2>
            <p class="large-text">The project’s second phase explores synchronization between telescopes. A close-distance proof of concept can use a shared master clock, while longer baselines may require GPS-disciplined oscillators.</p>
            <ul>
              <li>School nodes connected through an online network</li>
              <li>Research into phase comparison and correlation</li>
              <li>Collaborative STEM platform for students</li>
            </ul>
          </div>
          <div class="feature-image"><img src="assets/island_network.jpg" alt="Singapore school network concept map for collaborative telescope array" /></div>
        </div>
      </div>
    </section>

    <section id="roadmap">
      <div class="container">
        <div class="section-head reveal">
          <div class="label">Roadmap</div>
          <h2>Project timeline.</h2>
        </div>
        <div class="timeline">
          <div class="timeline-item reveal"><div class="month">January</div><div>Ideation and research.</div></div>
          <div class="timeline-item reveal"><div class="month">February</div><div>3D modelling and design.</div></div>
          <div class="timeline-item reveal"><div class="month">March</div><div>Fabrication and early prototype work.</div></div>
          <div class="timeline-item reveal"><div class="month">April</div><div>Proposal evaluation and design refinement.</div></div>
          <div class="timeline-item reveal"><div class="month">May</div><div>Complete core ASTRA 100A build.</div></div>
          <div class="timeline-item reveal"><div class="month">June–July</div><div>ASTRA 230A planning, synchronization blueprint, and proof-of-concept testing.</div></div>
          <div class="timeline-item reveal"><div class="month">August</div><div>Final evaluation, documentation, and public project presentation.</div></div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p>© 2026 Project ASTRA</p>
      <p>Amateur Synchronised Telescope for Radio Astronomy</p>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
